generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Пользователи ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  loginName     String    @unique
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole  @default(MEMBER)
  isServiceUser Boolean   @default(false)
  /// JSON: { "FOOD": 10000, "TRANSPORT": 5000, ... } лимиты в месяц по категориям (копейки/рубли — как решит фронт)
  monthlyBudgetByCategory Json?
  /// Ручная корректировка сембонов (к сумме из рейтинга)
  sembonManualAdjust Int     @default(0)
  bioNote       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events        Event[]
  eventReactions EventReaction[]
  comments      Comment[]
  expenses      Expense[]
  expensesAsBeneficiary Expense[] @relation("ExpenseBeneficiary")
  votes         Vote[]
  tasks         Task[]    @relation("TaskAssignee")
  tasksAuthored Task[]    @relation("TaskAuthor")
  tasksDone     Task[]    @relation("TaskCompleter")
  taskCompletionLogs TaskCompletionLog[]
  ratingPoints  RatingPoint[]
  pushSubscriptions PushSubscription[]
  dreamsAuthored Dream[]       @relation("DreamAuthor")
  dreamSupports  DreamSupport[] @relation("DreamSupporter")
  notifications  Notification[]
  appNewsComments AppNewsComment[]
  appNewsReactions AppNewsReaction[]
  appNewsVotes    AppNewsVote[]

  @@map("users")
}

// ─── Новости приложения (лента «Что нового») ─────────────────────────────────

model AppNews {
  id        String   @id @default(cuid())
  body      String   @db.Text
  createdAt DateTime @default(now())
  published Boolean  @default(true)

  comments  AppNewsComment[]
  reactions AppNewsReaction[]
  votes     AppNewsVote[]

  @@index([createdAt(sort: Desc)])
  @@map("app_news")
}

model AppNewsComment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  appNewsId String
  appNews   AppNews  @relation(fields: [appNewsId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([appNewsId])
  @@map("app_news_comments")
}

model AppNewsReaction {
  id        String   @id @default(cuid())
  appNewsId String
  appNews   AppNews  @relation(fields: [appNewsId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([appNewsId, userId, emoji])
  @@index([appNewsId])
  @@map("app_news_reactions")
}

model AppNewsVote {
  id        String    @id @default(cuid())
  value     VoteValue
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  appNewsId String
  appNews   AppNews   @relation(fields: [appNewsId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, appNewsId])
  @@map("app_news_votes")
}

// ─── Справочник категорий расходов (редактирует админ) ───────────────────────

model ExpenseCategoryDefinition {
  id        String  @id @default(cuid())
  code      String  @unique
  label     String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  @@map("expense_category_definitions")
}

/// Обучающие примеры: нормализованный текст позиции чека → категория (для ИИ и эвристик).
model ExpenseCategorySemanticHint {
  id           String   @id @default(cuid())
  textKey      String   @unique
  categoryCode String
  confirmCount Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("expense_category_semantic_hints")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  MEMBER
}

// ─── События / записи дневника ───────────────────────────────────────────────

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        EventType   @default(DIARY)
  status      EventStatus @default(ACTIVE)
  date        DateTime
  endDate     DateTime?
  imageUrl    String?
  links       EventLink[]
  authorId    String
  author      User        @relation(fields: [authorId], references: [id])
  comments    Comment[]
  votes       Vote[]
  reactions   EventReaction[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("events")
}

model EventReaction {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([eventId, userId, emoji])
  @@index([eventId])
  @@map("event_reactions")
}

enum EventType {
  DIARY
  PLAN
  BIRTHDAY
  HOLIDAY
  REMINDER
}

enum EventStatus {
  ACTIVE
  CANCELLED
  DONE
}

model EventLink {
  id      String @id @default(cuid())
  label   String
  url     String
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_links")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("comments")
}

model Vote {
  id        String    @id @default(cuid())
  value     VoteValue
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, eventId])
  @@map("votes")
}

enum VoteValue {
  UP
  DOWN
}

// ─── Справочник мест расходов ────────────────────────────────────────────────

model ExpensePlace {
  id       String    @id @default(cuid())
  name     String    @unique
  expenses Expense[]

  @@map("expense_places")
}

// ─── Расходы ─────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("RUB")
  /// Код из ExpenseCategoryDefinition (например FOOD)
  category    String          @default("UNRECOGNIZED")
  date        DateTime        @default(now())
  note        String?
  /// Произвольное фото к расходу
  imageUrl         String?
  /// Сжатый скан чека (ч/б, до ~100 КБ)
  receiptImageUrl  String?
  beneficiary ExpenseBeneficiary @default(FAMILY)
  beneficiaryUserId String?
  beneficiaryUser   User?    @relation("ExpenseBeneficiary", fields: [beneficiaryUserId], references: [id])
  placeId     String?
  place       ExpensePlace?   @relation(fields: [placeId], references: [id])
  authorId    String
  author      User            @relation(fields: [authorId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  /// Позиции из чека (одна запись расхода = сумма чека; строки — детализация)
  receiptLines ExpenseReceiptLine[]

  @@map("expenses")
}

model ExpenseReceiptLine {
  id        String   @id @default(cuid())
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  title     String
  amount    Decimal  @db.Decimal(10, 2)
  /// Код категории (разбор ИИ / вручную)
  category  String   @default("UNRECOGNIZED")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([expenseId])
  @@map("expense_receipt_lines")
}

enum ExpenseBeneficiary {
  FAMILY
  MEMBER
}

// ─── Задачи / обязанности ────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(DRAFT)
  points      Int        @default(10)
  /// Постановщик хочет заработать сембоны — активация только через согласование админа
  authorSeeksSembons Boolean @default(false)
  isRecurring Boolean @default(false)
  recurrenceKind TaskRecurrenceKind @default(NONE)
  /// WEEKLY: { "weekdays": number[] } (0=вс..6=сб); MONTHLY: { "dayOfMonth": number }; YEARLY: { "month": number, "day": number }
  recurrencePayload Json?
  /// Ближайший срок для регулярной задачи (для отображения)
  nextDueAt   DateTime?
  /// Для регулярных: дата окончания серии (после неё новые экземпляры не создаются)
  seriesEndsAt DateTime?
  authorId    String
  author      User       @relation("TaskAuthor", fields: [authorId], references: [id])
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedBy String?
  completer   User?      @relation("TaskCompleter", fields: [completedBy], references: [id])
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completionLogs TaskCompletionLog[]

  @@map("tasks")
}

model TaskCompletionLog {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  points      Int
  completedAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
  @@map("task_completion_logs")
}

enum TaskStatus {
  DRAFT
  APPROVAL_PENDING
  IN_PROGRESS
  IN_REVIEW
  DONE
  POSTPONED
  CANCELLED
  OVERDUE
}

enum TaskRecurrenceKind {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model RatingPoint {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  points    Int
  reason    String
  type      RatingPointType
  createdAt DateTime        @default(now())

  @@map("rating_points")
}

enum RatingPointType {
  TASK_DONE
  EVENT_CREATED
  VOTE_CAST
  EXPENSE_ADDED
  BONUS
  PENALTY
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ─── Мечты («Воплоти мечту») ─────────────────────────────────────────────────

model Dream {
  id         String      @id @default(cuid())
  orderNo    Int
  shortTitle String
  /// Текст с переносами; при необходимости позже подключим rich editor
  bodyRich   String      @db.Text
  status     DreamStatus @default(DRAFTING)
  authorId   String
  author     User        @relation("DreamAuthor", fields: [authorId], references: [id])
  supports   DreamSupport[]
  /// Когда все строки поддержки получили ответ — правки только у суперадмина
  lockedAt   DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([authorId])
  @@map("dreams")
}

enum DreamStatus {
  DRAFTING
  ACTIVE
  FULFILLED
  POSTPONED
  DROPPED
}

model DreamSupport {
  id               String               @id @default(cuid())
  dreamId          String
  dream            Dream                @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  supporterId      String
  supporter        User                 @relation("DreamSupporter", fields: [supporterId], references: [id])
  requestedSembons Int
  agreedSembons    Int?
  responseStatus   DreamSupportResponse @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([dreamId, supporterId])
  @@map("dream_supports")
}

enum DreamSupportResponse {
  PENDING
  DECLINED
  AGREED
}

// ─── Уведомления (в т.ч. по мечтам) ─────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}
