generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Пользователи ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  loginName     String    @unique
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole  @default(MEMBER)
  isServiceUser Boolean   @default(false)
  /// JSON: { "FOOD": 10000, "TRANSPORT": 5000, ... } лимиты в месяц по категориям (копейки/рубли — как решит фронт)
  monthlyBudgetByCategory Json?
  /// Ручная корректировка сембонов (к сумме из рейтинга)
  sembonManualAdjust Int     @default(0)
  bioNote       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events        Event[]
  comments      Comment[]
  expenses      Expense[]
  expensesAsBeneficiary Expense[] @relation("ExpenseBeneficiary")
  votes         Vote[]
  tasks         Task[]    @relation("TaskAssignee")
  tasksAuthored Task[]    @relation("TaskAuthor")
  tasksDone     Task[]    @relation("TaskCompleter")
  ratingPoints  RatingPoint[]
  pushSubscriptions PushSubscription[]
  dreamsAuthored Dream[]       @relation("DreamAuthor")
  dreamSupports  DreamSupport[] @relation("DreamSupporter")
  notifications  Notification[]

  @@map("users")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  MEMBER
}

// ─── События / записи дневника ───────────────────────────────────────────────

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        EventType   @default(DIARY)
  status      EventStatus @default(ACTIVE)
  date        DateTime
  endDate     DateTime?
  imageUrl    String?
  links       EventLink[]
  authorId    String
  author      User        @relation(fields: [authorId], references: [id])
  comments    Comment[]
  votes       Vote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("events")
}

enum EventType {
  DIARY
  PLAN
  BIRTHDAY
  HOLIDAY
  REMINDER
}

enum EventStatus {
  ACTIVE
  CANCELLED
  DONE
}

model EventLink {
  id      String @id @default(cuid())
  label   String
  url     String
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_links")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("comments")
}

model Vote {
  id        String    @id @default(cuid())
  value     VoteValue
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, eventId])
  @@map("votes")
}

enum VoteValue {
  UP
  DOWN
}

// ─── Справочник мест расходов ────────────────────────────────────────────────

model ExpensePlace {
  id       String    @id @default(cuid())
  name     String    @unique
  expenses Expense[]

  @@map("expense_places")
}

// ─── Расходы ─────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("RUB")
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())
  note        String?
  beneficiary ExpenseBeneficiary @default(FAMILY)
  beneficiaryUserId String?
  beneficiaryUser   User?    @relation("ExpenseBeneficiary", fields: [beneficiaryUserId], references: [id])
  placeId     String?
  place       ExpensePlace?   @relation(fields: [placeId], references: [id])
  authorId    String
  author      User            @relation(fields: [authorId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

enum ExpenseBeneficiary {
  FAMILY
  MEMBER
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ENTERTAINMENT
  HEALTH
  EDUCATION
  CLOTHING
  HOME
  VACATION
  SHOPPING_PLAN
  OTHER
}

// ─── Задачи / обязанности ────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(PENDING)
  points      Int        @default(10)
  authorId    String
  author      User       @relation("TaskAuthor", fields: [authorId], references: [id])
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedBy String?
  completer   User?      @relation("TaskCompleter", fields: [completedBy], references: [id])
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
}

model RatingPoint {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  points    Int
  reason    String
  type      RatingPointType
  createdAt DateTime        @default(now())

  @@map("rating_points")
}

enum RatingPointType {
  TASK_DONE
  EVENT_CREATED
  VOTE_CAST
  EXPENSE_ADDED
  BONUS
  PENALTY
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ─── Мечты («Воплоти мечту») ─────────────────────────────────────────────────

model Dream {
  id         String      @id @default(cuid())
  orderNo    Int
  shortTitle String
  /// Текст с переносами; при необходимости позже подключим rich editor
  bodyRich   String      @db.Text
  status     DreamStatus @default(DRAFTING)
  authorId   String
  author     User        @relation("DreamAuthor", fields: [authorId], references: [id])
  supports   DreamSupport[]
  /// Когда все строки поддержки получили ответ — правки только у суперадмина
  lockedAt   DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([authorId])
  @@map("dreams")
}

enum DreamStatus {
  DRAFTING
  ACTIVE
  FULFILLED
  POSTPONED
  DROPPED
}

model DreamSupport {
  id               String               @id @default(cuid())
  dreamId          String
  dream            Dream                @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  supporterId      String
  supporter        User                 @relation("DreamSupporter", fields: [supporterId], references: [id])
  requestedSembons Int
  agreedSembons    Int?
  responseStatus   DreamSupportResponse @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([dreamId, supporterId])
  @@map("dream_supports")
}

enum DreamSupportResponse {
  PENDING
  DECLINED
  AGREED
}

// ─── Уведомления (в т.ч. по мечтам) ─────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}
