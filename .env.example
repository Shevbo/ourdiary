# PostgreSQL connection string — подставьте свои USER, PASSWORD и хост (не оставляйте буквально HOST из примера).
# Локально: postgresql://USER:PASSWORD@127.0.0.1:5432/ourdiary?schema=public
# На сервере: хост, где слушает Postgres (часто 127.0.0.1 с той же машины, что и Node).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ourdiary?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
# За reverse-proxy (HTTPS): см. NextAuth — часто нужно AUTH_TRUST_HOST=true
# AUTH_TRUST_HOST="true"

# Единый вход Shectory: тот же пароль, что в каталоге портала (portal_users).
# Значение должно совпадать с SHECTORY_AUTH_BRIDGE_SECRET в .env портала на VDS.
# SHECTORY_AUTH_BRIDGE_SECRET=""
# SHECTORY_PORTAL_URL="https://shectory.ru"
# Для входа логином без «@» (до появления пользователя в БД): локальная_часть@SHECTORY_LOGIN_EMAIL_DOMAIN
# SHECTORY_LOGIN_EMAIL_DOMAIN="mail.ru"

# Импорт чеков по QR: позиции чека через API proverkacheka.com (см. docs/fiscal-receipts.md).
# Токен из личного кабинета — только строка, без квадратных скобок.
# PROVERKACHEKA_API_TOKEN=""
#
# Локальный сервис чтения QR с фото (PM2: ourdiary-qr-decode, порт 3912). Не путать с nginx-qrcode-server (генерация QR).
# OURDIARY_QR_DECODE_URL="http://127.0.0.1:3912"
# OURDIARY_QR_DECODE_SECRET="случайная-строка-та-же-что-QR_DECODE_SECRET-в-pm2"
# Публичный URL приложения. За nginx с доменом: https://ourdiary.shectory.ru (см. RUNBOOK.md)
NEXTAUTH_URL="http://127.0.0.1:3002"

# Порт процесса (на hoster по умолчанию 3002 — см. ecosystem.config.cjs)
PORT=3002

# App
NEXT_PUBLIC_APP_NAME="Наш дневник"
# Должен совпадать с тем, что видит браузер (схема + хост)
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3002"
